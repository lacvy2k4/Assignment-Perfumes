<!DOCTYPE html>
<html lang="en" data-theme="">
<script>document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || '');</script>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5/themes.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Profile - <%= member.name %>
    </title>
</head>

<body
    class="bg-base-100 min-h-screen antialiased text-base-content relative overflow-x-hidden transition-colors duration-300">

    <nav
        class="fixed top-6 left-1/2 -translate-x-1/2 w-[90%] max-w-5xl z-50 bg-base-100/50 backdrop-blur-[1px] saturate-[180%] border border-white/40 dark:border-white/10 shadow-[inset_0_1px_1px_rgba(255,255,255,0.4),0_8px_32px_0_rgba(0,0,0,0.1)] rounded-full px-8 py-4 flex justify-between items-center transition-all duration-500">

        <div class="relative text-2xl font-extrabold text-base-content z-10">
            <a href="/">StorePerfume</a>
        </div>
        <ul class="flex items-center gap-8 font-semibold text-base-content/80">
            <% if (member?.isAdmin) { %>
                <li>
                    <a href="/brands"
                        class="relative group/brands hover:text-indigo-600 transition-colors duration-300">
                        Brands
                        <span
                            class="absolute left-0 -bottom-1 w-0 h-0.5 bg-indigo-500 transition-all duration-300 group-hover/brands:w-full"></span>
                    </a>
                </li>
                <li>
                    <a href="/perfumes"
                        class="relative group/perfumes hover:text-indigo-600 transition-colors duration-300">
                        Perfumes
                        <span
                            class="absolute left-0 -bottom-1 w-0 h-0.5 bg-indigo-500 transition-all duration-300 group-hover/perfumes:w-full"></span>
                    </a>
                </li>
                <li>
                    <a href="/collectors"
                        class="relative group/collectors hover:text-indigo-600 transition-colors duration-300">
                        Collectors
                        <span
                            class="absolute left-0 -bottom-1 w-0 h-0.5 bg-indigo-500 transition-all duration-300 group-hover/collectors:w-full"></span>
                    </a>
                </li>
                <% } %>
                    <li class="dropdown dropdown-end">
                        <div tabindex="0" role="button"
                            class="flex items-center gap-2 hover:text-indigo-600 transition-colors duration-300 cursor-pointer">
                            <span class="font-bold">
                                <%= member.name %>
                            </span>
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                                xmlns="http://www.w3.org/2000/svg">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 9l-7 7-7-7">
                                </path>
                            </svg>
                        </div>
                        <ul tabindex="0"
                            class="dropdown-content menu bg-base-100/90 backdrop-blur-xl rounded-box z-[1] w-52 p-2 shadow border border-base-content/10 mt-4 gap-1 font-medium">
                            <li><a href="/profile"
                                    class="hover:bg-indigo-500/10 hover:text-indigo-600 rounded-lg">Profile</a></li>
                            <li><a href="/logout"
                                    class="text-error hover:bg-error/10 hover:text-error rounded-lg">Logout</a></li>
                        </ul>
                    </li>
                    <li class="flex items-center justify-center">
                        <label
                            class="swap swap-rotate text-base-content/70 hover:text-indigo-600 transition-colors duration-300">
                            <input type="checkbox" class="theme-controller" value="synthwave" />

                            <svg class="swap-off h-7 w-7 fill-current" xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24">
                                <path
                                    d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z" />
                            </svg>

                            <svg class="swap-on h-7 w-7 fill-current" xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24">
                                <path
                                    d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z" />
                            </svg>
                        </label>
                    </li>
        </ul>
    </nav>

    <main class="pt-40 px-6 max-w-3xl mx-auto flex flex-col items-center justify-center pb-16">

        <div
            class="w-full bg-base-100/40 backdrop-blur-lg border border-base-content/10 shadow-[0_8px_32px_0_rgba(0,0,0,0.08)] rounded-3xl p-8 md:p-12 transition-all duration-500">

            <a href="/"
                class="inline-flex items-center gap-2 mb-8 px-5 py-2.5 rounded-full bg-base-100/50 border border-base-content/10 text-base-content/70 font-medium hover:shadow-md hover:text-indigo-600 hover:border-indigo-500/30 transition-all duration-300 group">
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1" fill="none"
                    stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
                Back to Home
            </a>

            <div class="flex flex-col items-center gap-4 mb-10">
                <div
                    class="w-24 h-24 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-4xl font-bold shadow-lg">
                    <%= member.name.charAt(0).toUpperCase() %>
                </div>
                <div class="text-center">
                    <h1 class="text-3xl font-extrabold text-base-content">
                        <%= member.name %>
                    </h1>
                    <p class="text-base-content/50 text-sm mt-1">
                        <% if (member.isAdmin) { %>
                            <span
                                class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-indigo-500/10 text-indigo-600 text-xs font-semibold">
                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd" />
                                </svg>
                                Administrator
                            </span>
                            <% } else { %>
                                <span class="text-base-content/40">Member</span>
                                <% } %>
                    </p>
                </div>
            </div>

            <div class="w-full h-px bg-gradient-to-r from-transparent via-base-content/15 to-transparent mb-8"></div>

            <div
                class="rounded-2xl bg-base-100/40 backdrop-blur-lg border border-white/40 dark:border-white/10 shadow-[inset_0_1px_1px_rgba(255,255,255,0.4),0_8px_32px_0_rgba(0,0,0,0.08)] overflow-hidden">
                <div class="grid grid-cols-1 md:grid-cols-2">

                    <div
                        class="flex items-center gap-4 px-6 py-5 transition-colors duration-200 hover:bg-base-content/[0.03]">
                        <div
                            class="flex-shrink-0 w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-xs text-base-content/40 uppercase tracking-wider font-semibold">Email</p>
                            <p class="text-base-content font-medium mt-0.5 truncate">
                                <%= member.email %>
                            </p>
                        </div>
                    </div>

                    <div
                        class="flex items-center gap-4 px-6 py-5 transition-colors duration-200 hover:bg-base-content/[0.03]">
                        <div
                            class="flex-shrink-0 w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-xs text-base-content/40 uppercase tracking-wider font-semibold">Full Name</p>
                            <p class="text-base-content font-medium mt-0.5">
                                <%= member.name %>
                            </p>
                        </div>
                    </div>



                    <div
                        class="flex items-center gap-4 px-6 py-5 transition-colors duration-200 hover:bg-base-content/[0.03]">
                        <div
                            class="flex-shrink-0 w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-xs text-base-content/40 uppercase tracking-wider font-semibold">Year of Birth
                            </p>
                            <p class="text-base-content font-medium mt-0.5">
                                <%= member.YOB %>
                            </p>
                        </div>
                    </div>

                    <div
                        class="flex items-center gap-4 px-6 py-5 transition-colors duration-200 hover:bg-base-content/[0.03]">
                        <div
                            class="flex-shrink-0 w-10 h-10 rounded-xl bg-rose-500/10 flex items-center justify-center text-rose-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                            </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-xs text-base-content/40 uppercase tracking-wider font-semibold">Gender</p>
                            <p class="text-base-content font-medium mt-0.5">
                                <%= member.gender ? 'Male' : 'Female' %>
                            </p>
                        </div>
                    </div>

                </div>
            </div>

            <div class="w-full h-px bg-gradient-to-r from-transparent via-base-content/15 to-transparent my-8"></div>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <button onclick="openEditModal()"
                    class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-semibold shadow-lg hover:shadow-xl hover:opacity-90 transition-all duration-300 transform hover:-translate-y-0.5 cursor-pointer">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                    Edit Profile
                </button>
                <button onclick="openPasswordModal()"
                    class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full bg-base-100/60 backdrop-blur-lg border border-base-content/20 text-base-content font-semibold shadow-md hover:shadow-xl hover:bg-base-100/80 transition-all duration-300 transform hover:-translate-y-0.5 cursor-pointer">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    Change Password
                </button>
            </div>
        </div>
    </main>

    <dialog id="editModal" class="modal">
        <div
            class="modal-box bg-base-100/80 backdrop-blur-xl border border-base-content/10 rounded-3xl shadow-2xl max-w-md">
            <form method="dialog">
                <button class="btn btn-sm btn-circle btn-ghost absolute right-4 top-4">✕</button>
            </form>
            <h3 class="text-xl font-bold text-base-content mb-6">Edit Profile</h3>
            <form id="editForm" class="flex flex-col gap-4">
                <div>
                    <label class="text-xs text-base-content/50 uppercase tracking-wider font-semibold">Name</label>
                    <input type="text" name="name" value="<%= member.name %>"
                        class="mt-1 w-full px-4 py-3 bg-base-100/50 border border-base-content/15 rounded-xl text-base-content focus:outline-none focus:ring-2 focus:ring-indigo-500/50 transition-all" />
                </div>
                <div>
                    <label class="text-xs text-base-content/50 uppercase tracking-wider font-semibold">Year of
                        Birth</label>
                    <input type="number" name="YOB" value="<%= member.YOB %>"
                        class="mt-1 w-full px-4 py-3 bg-base-100/50 border border-base-content/15 rounded-xl text-base-content focus:outline-none focus:ring-2 focus:ring-indigo-500/50 transition-all" />
                </div>
                <div>
                    <label class="text-xs text-base-content/50 uppercase tracking-wider font-semibold">Gender</label>
                    <select name="gender"
                        class="mt-1 w-full px-4 py-3 bg-base-100/50 border border-base-content/15 rounded-xl text-base-content focus:outline-none focus:ring-2 focus:ring-indigo-500/50 transition-all">
                        <option value="true" <%=member.gender ? 'selected' : '' %>>Male</option>
                        <option value="false" <%=!member.gender ? 'selected' : '' %>>Female</option>
                    </select>
                </div>
                <button type="submit"
                    class="mt-2 w-full py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-semibold shadow-lg hover:shadow-xl hover:opacity-90 transition-all duration-300 cursor-pointer">
                    Save Changes
                </button>
            </form>
            <div id="editMsg" class="mt-3 text-center text-sm hidden"></div>
        </div>
        <form method="dialog" class="modal-backdrop">
            <button>close</button>
        </form>
    </dialog>

    <dialog id="passwordModal" class="modal">
        <div
            class="modal-box bg-base-100/80 backdrop-blur-xl border border-base-content/10 rounded-3xl shadow-2xl max-w-md">
            <form method="dialog">
                <button class="btn btn-sm btn-circle btn-ghost absolute right-4 top-4">✕</button>
            </form>
            <h3 class="text-xl font-bold text-base-content mb-6">Change Password</h3>
            <form id="passwordForm" class="flex flex-col gap-4">
                <div>
                    <label class="text-xs text-base-content/50 uppercase tracking-wider font-semibold">Current
                        Password</label>
                    <input type="password" name="currentPassword" required
                        class="mt-1 w-full px-4 py-3 bg-base-100/50 border border-base-content/15 rounded-xl text-base-content focus:outline-none focus:ring-2 focus:ring-indigo-500/50 transition-all"
                        placeholder="Enter current password" />
                </div>
                <div>
                    <label class="text-xs text-base-content/50 uppercase tracking-wider font-semibold">New
                        Password</label>
                    <input type="password" name="newPassword" required
                        class="mt-1 w-full px-4 py-3 bg-base-100/50 border border-base-content/15 rounded-xl text-base-content focus:outline-none focus:ring-2 focus:ring-indigo-500/50 transition-all"
                        placeholder="Enter new password" />
                </div>
                <div>
                    <label class="text-xs text-base-content/50 uppercase tracking-wider font-semibold">Confirm New
                        Password</label>
                    <input type="password" name="confirmPassword" required
                        class="mt-1 w-full px-4 py-3 bg-base-100/50 border border-base-content/15 rounded-xl text-base-content focus:outline-none focus:ring-2 focus:ring-indigo-500/50 transition-all"
                        placeholder="Confirm new password" />
                </div>
                <button type="submit"
                    class="mt-2 w-full py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-semibold shadow-lg hover:shadow-xl hover:opacity-90 transition-all duration-300 cursor-pointer">
                    Update Password
                </button>
            </form>
            <div id="pwMsg" class="mt-3 text-center text-sm hidden"></div>
        </div>
        <form method="dialog" class="modal-backdrop">
            <button>close</button>
        </form>
    </dialog>

    <script>
        function openEditModal() {
            document.getElementById('editModal').showModal();
        }
        function openPasswordModal() {
            document.getElementById('passwordModal').showModal();
        }

        function showMsg(el, message, isSuccess) {
            el.textContent = message;
            el.className = 'mt-3 text-center text-sm font-medium ' + (isSuccess ? 'text-green-500' : 'text-red-500');
            el.classList.remove('hidden');
        }

        document.getElementById('editForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const msgEl = document.getElementById('editMsg');
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);
            try {
                const res = await fetch('/profile', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                showMsg(msgEl, result.message, result.status);
                if (result.status) {
                    setTimeout(() => location.reload(), 1000);
                }
            } catch (err) {
                showMsg(msgEl, 'An error occurred, please try again.', false);
            }
        });

        document.getElementById('passwordForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const msgEl = document.getElementById('pwMsg');
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);

            if (data.newPassword !== data.confirmPassword) {
                return showMsg(msgEl, 'New passwords do not match.', false);
            }

            try {
                const res = await fetch('/profile', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        currentPassword: data.currentPassword,
                        newPassword: data.newPassword
                    })
                });
                const result = await res.json();
                showMsg(msgEl, result.message, result.status);
                if (result.status) {
                    this.reset();
                    setTimeout(() => {
                        document.getElementById('passwordModal').close();
                    }, 1500);
                }
            } catch (err) {
                showMsg(msgEl, 'An error occurred, please try again.', false);
            }
        });

        (function () {
            const themeCheckbox = document.querySelector('.theme-controller');
            if (themeCheckbox) {
                themeCheckbox.checked = localStorage.getItem('theme') === 'synthwave';
                themeCheckbox.addEventListener('change', function () {
                    const theme = this.checked ? 'synthwave' : '';
                    localStorage.setItem('theme', theme);
                    document.documentElement.setAttribute('data-theme', theme);
                });
            }
        })();
    </script>

</body>

</html>