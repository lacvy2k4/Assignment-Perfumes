<!DOCTYPE html>
<html lang="en" data-theme="">
<script>document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || '');</script>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5/themes.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>
        <%= brand.brandName %> - Brand Detail
    </title>
</head>

<body class="bg-base-200 min-h-screen">

    <div class="max-w-4xl mx-auto px-6 pt-8">
        <a href="/brands"
            class="inline-flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span class="font-medium">Back to Brands</span>
        </a>
    </div>

    <main class="max-w-4xl mx-auto px-6 py-8">
        <div class="bg-base-100 rounded-2xl shadow-lg border border-base-content/10 p-8">

            <div class="flex items-center justify-between mb-6">
                <h1 class="text-3xl font-serif font-light text-base-content tracking-wide">Brand Detail</h1>
                <div class="flex gap-2">
                    <button onclick="document.getElementById('editModal').showModal()" class="btn btn-sm btn-info">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Edit
                    </button>
                    <button onclick="document.getElementById('deleteModal').showModal()" class="btn btn-sm btn-error">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Delete
                    </button>
                </div>
            </div>

            <div class="divider"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <p class="text-xs text-base-content/40 uppercase tracking-widest mb-1">Brand Name</p>
                    <p id="brandNameDisplay" class="text-xl font-semibold text-base-content">
                        <%= brand.brandName %>
                    </p>
                </div>
                <div>
                    <p class="text-xs text-base-content/40 uppercase tracking-widest mb-1">Created At</p>
                    <p class="text-base-content/70">
                        <%= new Date(brand.createdAt).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' ,
                            day: 'numeric' }) %>
                    </p>
                </div>
                <div>
                    <p class="text-xs text-base-content/40 uppercase tracking-widest mb-1">Updated At</p>
                    <p class="text-base-content/70">
                        <%= new Date(brand.updatedAt).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' ,
                            day: 'numeric' }) %>
                    </p>
                </div>
                <div>
                    <p class="text-xs text-base-content/40 uppercase tracking-widest mb-1">ID</p>
                    <p class="text-base-content/50 font-mono text-sm">
                        <%= brand._id %>
                    </p>
                </div>
            </div>
        </div>
    </main>

    <dialog id="editModal" class="modal">
        <div class="modal-box rounded-2xl">
            <h3 class="text-xl font-semibold text-base-content mb-4">Edit Brand</h3>
            <input id="editBrandName" type="text" placeholder="Brand name" class="input input-bordered w-full mb-2"
                value="<%= brand.brandName %>" />
            <div id="editError" class="text-error text-sm hidden mb-2"></div>
            <div class="modal-action">
                <button onclick="document.getElementById('editModal').close()" class="btn btn-ghost">Cancel</button>
                <button onclick="updateBrand()" class="btn btn-info">Update</button>
            </div>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>

    <dialog id="deleteModal" class="modal">
        <div class="modal-box rounded-2xl">
            <h3 class="text-xl font-semibold text-base-content mb-2">Delete Brand</h3>
            <p class="text-base-content/70">Are you sure you want to delete <strong>
                    <%= brand.brandName %>
                </strong>?
                This action cannot be undone.</p>
            <div id="deleteError" class="text-error text-sm hidden mt-2"></div>
            <div class="modal-action">
                <button onclick="document.getElementById('deleteModal').close()" class="btn btn-ghost">Cancel</button>
                <button onclick="deleteBrand()" class="btn btn-error">Delete</button>
            </div>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>

    <script>
        async function updateBrand() {
            const name = document.getElementById('editBrandName').value.trim();
            const errorDiv = document.getElementById('editError');
            errorDiv.classList.add('hidden');
            if (!name) {
                errorDiv.textContent = 'Brand name is required.';
                errorDiv.classList.remove('hidden');
                return;
            }
            try {
                const res = await fetch('/brands/<%= brand._id %>', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ brandName: name })
                });
                const data = await res.json();
                if (data.status) {
                    window.location.reload();
                } else {
                    errorDiv.textContent = data.message || 'Failed to update brand.';
                    errorDiv.classList.remove('hidden');
                }
            } catch (err) {
                errorDiv.textContent = 'Network error.';
                errorDiv.classList.remove('hidden');
            }
        }

        async function deleteBrand() {
            const errorDiv = document.getElementById('deleteError');
            errorDiv.classList.add('hidden');
            try {
                const res = await fetch('/brands/<%= brand._id %>', { method: 'DELETE' });
                const data = await res.json();
                if (data.status) {
                    window.location.href = '/brands';
                } else {
                    errorDiv.textContent = data.message || 'Failed to delete brand.';
                    errorDiv.classList.remove('hidden');
                }
            } catch (err) {
                errorDiv.textContent = 'Network error.';
                errorDiv.classList.remove('hidden');
            }
        }
    </script>

</body>

</html>